<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Version>10.1.1</Version>
		<FileVersion>10.1.1</FileVersion>
		<AssemblyVersion>10.1.1</AssemblyVersion>
		<Authors>Daniel M. Porrey, Harshit Gindra</Authors>
		<Product>Diamond Pattern Library - Rules Pattern</Product>
		<Description>This library provides abstractions for the Rules pattern.</Description>
		<Copyright>Copyright © Daniel Porrey 2017-2021</Copyright>
		<PackageLicenseExpression>LGPL-3.0-or-later</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/porrey/Diamond.Core-Patterns</PackageProjectUrl>
		<RepositoryUrl>https://github.com/porrey/Diamond.Core-Patterns</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageIconUrl>
		</PackageIconUrl>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
		<PackageIcon>Diamond.Core.128x128.png</PackageIcon>
		<NeutralLanguage>English (United States)</NeutralLanguage>
		<Company>Daniel M. Porrey</Company>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>
	<PropertyGroup>
		<DocumentationFile>XmlDocs\Diamond.Core.Rules.Abstractions.xml</DocumentationFile>
	</PropertyGroup>
	<ItemGroup>
		<None Remove="Diamond.Core.Rules.Abstractions.xml" />
		<None Remove="Services\Diamond.Core.Rules.Abstractions.json" />
		<None Remove="XmlDocs\Diamond.Core.Rules.Abstractions.xml" />
	</ItemGroup>
	<ItemGroup>
		<Content Include="Services\Diamond.Core.Rules.Abstractions.json">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<Content Include="XmlDocs\Diamond.Core.Rules.Abstractions.xml">
		  <CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
	</ItemGroup>
	<ItemGroup>
		<None Include="..\..\..\README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
		<None Include="..\..\..\Images\Diamond.Core.128x128.png">
			<Pack>True</Pack>
			<PackagePath>
			</PackagePath>
		</None>
	</ItemGroup>
</Project>